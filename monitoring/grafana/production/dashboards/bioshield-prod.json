{
  "title": "BioShield Production Dashboard",
  "uid": "bioshield-prod",
  "tags": ["production", "security", "bioshield"],
  "timezone": "utc",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Real-time Deepfake Detection Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(bioshield_deepfake_detections_total[1m])",
        "legendFormat": "Deepfakes/sec"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "API Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(bioshield_request_latency_seconds_bucket[5m])) by (le))",
        "legendFormat": "p99 Latency"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 15},
              {"color": "red", "value": 30}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Streams",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 8},
      "targets": [{"expr": "bioshield_active_streams"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 4,
      "title": "SLA Uptime",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 8},
      "targets": [{"expr": "100 - (sum(up{job='bioshield-api'} == 0) / count(up{job='bioshield-api'}) * 100)"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 99.9}, {"color": "yellow", "value": 99.99}, {"color": "green", "value": 99.999}]}}}
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 8},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[2m])) * 100)"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 60}, {"color": "yellow", "value": 80}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 6,
      "title": "Alert Status",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "ALERTS{alertstate='firing'}", "format": "table"}]
    }
  ],
  "time": {"from": "now-6h", "to": "now"},
  "schemaVersion": 38,
  "version": 1
}
