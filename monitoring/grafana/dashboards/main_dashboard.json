{
  "title": "Sovereign Bio-Shield Main Dashboard",
  "uid": "bioshield-main",
  "tags": ["security", "deepfake", "realtime"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Real-time Deepfake Detection Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(bioshield_deepfake_detections_total[1m])",
        "legendFormat": "Deepfakes/sec"
      }]
    },
    {
      "id": 2,
      "title": "API Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(bioshield_request_latency_seconds_bucket[5m])) by (le))",
        "legendFormat": "p99 Latency"
      }]
    },
    {
      "id": 3,
      "title": "Active Streams",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 8},
      "targets": [{
        "expr": "bioshield_active_streams"
      }]
    },
    {
      "id": 4,
      "title": "Total Scans Today",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 8},
      "targets": [{
        "expr": "sum(increase(bioshield_requests_total[1d]))"
      }]
    },
    {
      "id": 5,
      "title": "Blocked IPs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 8},
      "targets": [{
        "expr": "bioshield_ebpf_blocked_ips"
      }]
    },
    {
      "id": 6,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)"
      }]
    },
    {
      "id": 7,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
      "targets": [{
        "expr": "100 - (node_memory_MemFree_bytes / node_memory_MemTotal_bytes * 100)"
      }]
    }
  ]
}
